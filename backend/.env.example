# ============================================
# Quant Analysis System 环境变量配置示例
# 复制此文件为 .env 并根据需要修改
# ============================================

# ----------------------------------------
# 应用配置（可选）
# ----------------------------------------
# 应用名称
# APP_NAME=量化分析系统

# 应用版本
# APP_VERSION=1.0.0

# 调试模式: True 或 False
# DEBUG=True

# ----------------------------------------
# 数据目录配置（可选）
# ----------------------------------------
# 数据根目录，默认: ~/.quant
# QUANT_DATA_DIR=/path/to/your/data

# SQLite 数据库目录，默认: $QUANT_DATA_DIR/sqlite
# QUANT_SQLITE_DIR=/path/to/your/sqlite

# Parquet 数据目录，默认: $QUANT_DATA_DIR/parquet
# QUANT_PARQUET_DIR=/path/to/your/parquet

# 日志目录，默认: $QUANT_DATA_DIR/logs
# QUANT_LOG_DIR=/path/to/your/logs

# ----------------------------------------
# 数据库配置（可选）
# ----------------------------------------
# 完整的数据库URL，覆盖上述目录配置
# 默认: sqlite+aiosqlite:///$QUANT_DATA_DIR/sqlite/quant.db
# DATABASE_URL=sqlite+aiosqlite:////path/to/your/quant.db

# ----------------------------------------
# 日志配置（可选）
# ----------------------------------------
# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
# QUANT_LOG_LEVEL=INFO

# 日志文件路径
# LOG_FILE=./logs/quant.log

# ----------------------------------------
# 缓存配置（可选，单位：秒）
# ----------------------------------------
# 热数据阈值（天）
# QUANT_HOT_THRESHOLD_DAYS=90

# 实时行情缓存 TTL
# QUANT_CACHE_TTL_REALTIME=60

# K线缓存 TTL
# QUANT_CACHE_TTL_KLINE=300

# 指标缓存 TTL
# QUANT_CACHE_TTL_INDICATORS=300

# 板块缓存 TTL
# QUANT_CACHE_TTL_SECTOR=300

# 筹码缓存 TTL
# QUANT_CACHE_TTL_CHIP=600

# 回测缓存 TTL
# QUANT_CACHE_TTL_BACKTEST=3600

# 最大缓存条目数
# MAX_CACHE_SIZE=1000

# ----------------------------------------
# CORS 配置（可选）
# ----------------------------------------
# 允许的前端地址（JSON 数组格式）
# CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# ----------------------------------------
# JWT 认证配置（可选）
# ----------------------------------------
# JWT 加密算法
# JWT_ALGORITHM=HS256

# Access Token 过期时间（分钟）
# ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ----------------------------------------
# 安全配置（生产环境必须设置！）
# ----------------------------------------
# JWT 密钥，建议使用: openssl rand -hex 32
# 生成命令: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-key-at-least-32-characters-long

# ----------------------------------------
# 默认用户密码（仅开发环境，生产环境必须修改！）
# ----------------------------------------
# 管理员密码
# DEFAULT_ADMIN_PASSWORD=admin123

# 普通用户密码
# DEFAULT_USER_PASSWORD=user123

# ----------------------------------------
# 回测配置（可选）
# ----------------------------------------
# 初始资金
# BACKTEST_INITIAL_CAPITAL=1000000

# 佣金率
# BACKTEST_COMMISSION=0.0003

# 滑点
# BACKTEST_SLIPPAGE=0.0001

# ----------------------------------------
# 数据源配置（可选）
# ----------------------------------------
# 默认数据源: efinance, akshare, baostock, tickflow
# 详细策略配置见 app/adapters/strategy_config.py
DEFAULT_DATA_SOURCE=efinance

# TickFlow API Key（可选，用于获取高质量数据）
# 官网: https://tickflow.tech
TICKFLOW_API_KEY=your-tickflow-api-key

# ----------------------------------------
# API 配置（可选）
# ----------------------------------------
# API 前缀
# API_PREFIX=/api/v1
