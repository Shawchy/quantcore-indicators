# ============================================================
# 量化分析系统 - 环境变量配置模板
# ============================================================
# 使用说明：
# 1. 从 Git 拉取项目后，复制此文件为 .env
# 2. 命令：cp .env.example .env
# 3. 根据实际环境修改配置项
# 4. SECRET_KEY 必须重新生成（生产环境）
# ============================================================

# ------------------------------------------------------------
# 应用配置
# ------------------------------------------------------------
APP_NAME=量化分析系统
APP_VERSION=1.0.0
DEBUG=True

# ------------------------------------------------------------
# 安全配置（生产环境必须修改！）
# ------------------------------------------------------------
# 生成新的 SECRET_KEY 命令：
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# 或使用：
#   openssl rand -hex 32
SECRET_KEY=your-super-secret-key-at-least-32-characters-long

# ------------------------------------------------------------
# 数据库配置
# ------------------------------------------------------------
SQLITE_DIR=./data/sqlite
PARQUET_DIR=./data/parquet

# ------------------------------------------------------------
# CORS 配置（前端跨域访问）
# ------------------------------------------------------------
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://127.0.0.1:5173","http://127.0.0.1:3000"]

# ------------------------------------------------------------
# 日志配置
# ------------------------------------------------------------
LOG_FILE=./logs/quant.log
LOG_LEVEL=INFO

# ------------------------------------------------------------
# JWT 认证配置
# ------------------------------------------------------------
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ------------------------------------------------------------
# 回测配置
# ------------------------------------------------------------
BACKTEST_INITIAL_CAPITAL=1000000
BACKTEST_COMMISSION=0.0003
BACKTEST_SLIPPAGE=0.0001

# ------------------------------------------------------------
# 数据源配置
# ------------------------------------------------------------
DEFAULT_DATA_SOURCE=efinance
DATA_SOURCE_PRIORITY=["efinance","akshare","baostock","tickflow"]

# ------------------------------------------------------------
# TickFlow 配置（可选）
# ------------------------------------------------------------
# TickFlow 是一个金融数据服务，提供实时行情和历史数据
# 官网：https://tickflow.tech
# 
# 免费服务（无需 API Key）：
#   - 日 K 线数据（1d、1w、1M、1Q、1Y）
#   - 标的信息查询
# 
# 完整服务（需要 API Key）：
#   - 实时行情
#   - 分钟级 K 线（1m、5m、15m、30m、60m）
#   - 更多高级功能
#
# 获取 API Key：
#   1. 访问 https://tickflow.tech 注册账号
#   2. 在个人中心获取 API Key
#   3. 填写到下方配置项
#
# 注意：如果不配置，将自动使用免费服务
# TICKFLOW_API_KEY=tk_your-api-key-here

# ------------------------------------------------------------
# 缓存配置
# ------------------------------------------------------------
CACHE_TTL=300
MAX_CACHE_SIZE=1000

# ------------------------------------------------------------
# 默认用户密码（仅开发环境，生产环境必须修改！）
# ------------------------------------------------------------
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_USER_PASSWORD=user123

# ------------------------------------------------------------
# API 配置
# ------------------------------------------------------------
API_PREFIX=/api/v1
