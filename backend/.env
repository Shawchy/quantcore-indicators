# ============================================================
# 量化分析系统 - 环境变量配置
# ============================================================
# 使用说明：
# 1. 此文件包含敏感信息，请勿提交到版本控制系统
# 2. 生产环境必须修改 SECRET_KEY
# ============================================================

# ------------------------------------------------------------
# 应用配置
# ------------------------------------------------------------
APP_NAME=量化分析系统
APP_VERSION=1.0.0
DEBUG=True

# ------------------------------------------------------------
# 安全配置（生产环境必须修改！）
# ------------------------------------------------------------
# 生成新的 SECRET_KEY 命令：
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# 或使用：
#   openssl rand -hex 32
SECRET_KEY=your-super-secret-key-at-least-32-characters-long

# ------------------------------------------------------------
# 数据库配置
# ------------------------------------------------------------
SQLITE_DIR=./data/sqlite
PARQUET_DIR=./data/parquet

# ------------------------------------------------------------
# CORS 配置（前端跨域访问）
# ------------------------------------------------------------
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://127.0.0.1:5173","http://127.0.0.1:3000"]

# ------------------------------------------------------------
# 日志配置
# ------------------------------------------------------------
LOG_FILE=./logs/quant.log
LOG_LEVEL=INFO

# ------------------------------------------------------------
# JWT 认证配置
# ------------------------------------------------------------
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ------------------------------------------------------------
# 回测配置
# ------------------------------------------------------------
BACKTEST_INITIAL_CAPITAL=1000000
BACKTEST_COMMISSION=0.0003
BACKTEST_SLIPPAGE=0.0001

# ------------------------------------------------------------
# 数据源配置
# ------------------------------------------------------------
# 默认数据源（可选：efinance, akshare, baostock, tickflow）
# 详细策略配置见 app/adapters/strategy_config.py
DEFAULT_DATA_SOURCE=efinance

# ------------------------------------------------------------
# TickFlow 配置
# ------------------------------------------------------------
# TickFlow 是一个金融数据服务，提供实时行情和历史数据
# 官网：https://tickflow.tech
# 注意：请从环境变量注入真实 API Key，不要在此处硬编码
TICKFLOW_API_KEY=

# ------------------------------------------------------------
# 缓存配置
# ------------------------------------------------------------
CACHE_TTL=300
MAX_CACHE_SIZE=1000

# ------------------------------------------------------------
# 默认用户密码（仅开发环境，生产环境必须修改！）
# ------------------------------------------------------------
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_USER_PASSWORD=user123

# ------------------------------------------------------------
# API 配置
# ------------------------------------------------------------
API_PREFIX=/api/v1

# ------------------------------------------------------------
# Ollama LLM 服务配置
# ------------------------------------------------------------
# Ollama 服务地址和端口，用于模型推理（如 qwen3:8b-financial）
OLLAMA_HOST=localhost
OLLAMA_PORT=11434
