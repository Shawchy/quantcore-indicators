# ============================================
# Quant Analysis System 环境变量配置示例
# 复制此文件为 .env 并根据需要修改
# ============================================

# ----------------------------------------
# 数据目录配置（可选）
# ----------------------------------------
# 数据根目录，默认: ~/.quant
# QUANT_DATA_DIR=/path/to/your/data

# SQLite 数据库目录，默认: $QUANT_DATA_DIR/sqlite
# QUANT_SQLITE_DIR=/path/to/your/sqlite

# Parquet 数据目录，默认: $QUANT_DATA_DIR/parquet
# QUANT_PARQUET_DIR=/path/to/your/parquet

# 日志目录，默认: $QUANT_DATA_DIR/logs
# QUANT_LOG_DIR=/path/to/your/logs

# ----------------------------------------
# 数据库配置（可选）
# ----------------------------------------
# 完整的数据库URL，覆盖上述目录配置
# 默认: sqlite+aiosqlite:///$QUANT_DATA_DIR/sqlite/quant.db
# DATABASE_URL=sqlite+aiosqlite:////path/to/your/quant.db

# ----------------------------------------
# 日志配置（可选）
# ----------------------------------------
# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
# QUANT_LOG_LEVEL=INFO

# ----------------------------------------
# 缓存配置（可选，单位：秒）
# ----------------------------------------
# 热数据阈值（天）
# QUANT_HOT_THRESHOLD_DAYS=90

# 实时行情缓存 TTL
# QUANT_CACHE_TTL_REALTIME=60

# K线缓存 TTL
# QUANT_CACHE_TTL_KLINE=300

# 指标缓存 TTL
# QUANT_CACHE_TTL_INDICATORS=300

# 板块缓存 TTL
# QUANT_CACHE_TTL_SECTOR=300

# 筹码缓存 TTL
# QUANT_CACHE_TTL_CHIP=600

# 回测缓存 TTL
# QUANT_CACHE_TTL_BACKTEST=3600

# ----------------------------------------
# 安全配置（生产环境必须设置）
# ----------------------------------------
# JWT 密钥，建议使用: openssl rand -hex 32
# SECRET_KEY=your-secret-key-here

# 默认管理员密码（首次启动后应立即修改）
# ADMIN_PASSWORD=your-secure-password

# ----------------------------------------
# 数据源配置（可选）
# ----------------------------------------
# 默认数据源: efinance, akshare, baostock, tickflow
# DEFAULT_DATA_SOURCE=efinance

# TickFlow API Key（可选）
# TICKFLOW_API_KEY=your-api-key
