    "@tanstack/react-virtual": "^3.13.24",
    "axios": "^1.16.1",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.6",
    "klinecharts": "^10.0.0-beta1",
    "next-themes": "^0.4.6",
    "react": "^19.2.6",
