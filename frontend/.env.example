# 环境变量配置示例
# 复制此文件为 .env 或 .env.local 使用

# ==================== API 配置 ====================
# 后端 API 地址（注意：需要包含 /api/v1 前缀）
VITE_API_BASE_URL=http://localhost:8000/api/v1

# WebSocket 地址
VITE_WS_URL=ws://localhost:8000/api/v1/ws

# ==================== Sentry 错误监控 ====================
# Sentry DSN (在 Sentry 项目中获取)
# 获取方式：登录 Sentry -> 选择项目 -> Project Settings -> Client Keys (DSN)
VITE_SENTRY_DSN=https://your-dsn-key@o0.ingest.sentry.io/0

# ==================== 应用配置 ====================
# 应用标题
VITE_APP_TITLE=Quant 股票量化分析系统

# 应用版本
VITE_APP_VERSION=1.0.0

# ==================== 功能开关 ====================
# 是否启用调试模式
VITE_DEBUG=true

# 是否启用性能监控
VITE_ENABLE_PERFORMANCE=true

# 是否启用日志
VITE_ENABLE_LOGS=true

# ==================== TICKFLOW 数据源配置 ====================
# TICKFLOW API Key (用于访问 TickFlow 数据源)
# 获取方式：联系 TickFlow 服务提供商
VITE_TICKFLOW_API_KEY=your-tickflow-api-key

# ==================== 其他第三方服务 ====================
# 地图服务 Key (如使用)
# VITE_MAP_KEY=your-map-key

# 推送服务 Key (如使用)
# VITE_PUSH_KEY=your-push-key

# ==================== 构建配置 ====================
# 构建环境标识
# 开发环境：development
# 测试环境：test
# 生产环境：production
VITE_BUILD_ENV=development
