# ============================================================
# 量化分析系统 - 环境变量配置文件
# ============================================================
# 使用说明：
# 1. 从 Git 拉取项目后，复制此文件为 .env
# 2. 根据实际环境修改配置项
# 3. SECRET_KEY 必须重新生成（生产环境）
# ============================================================

# ------------------------------------------------------------
# 应用配置
# ------------------------------------------------------------
APP_NAME=量化分析系统
APP_VERSION=1.0.0
DEBUG=True

# ------------------------------------------------------------
# 安全配置（生产环境必须修改！）
# ------------------------------------------------------------
# 生成新的 SECRET_KEY 命令：python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=7SFtoX4y7uryQ3Cqxe59g_CKZvKativ5ikUIks2xmfw

# ------------------------------------------------------------
# 数据库配置
# ------------------------------------------------------------
SQLITE_DIR=./data/sqlite
PARQUET_DIR=./data/parquet

# ------------------------------------------------------------
# CORS 配置（前端跨域访问）
# ------------------------------------------------------------
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://127.0.0.1:5173","http://127.0.0.1:3000"]

# ------------------------------------------------------------
# 日志配置
# ------------------------------------------------------------
LOG_FILE=./logs/quant.log
LOG_LEVEL=INFO

# ------------------------------------------------------------
# JWT 认证配置
# ------------------------------------------------------------
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ------------------------------------------------------------
# 回测配置
# ------------------------------------------------------------
BACKTEST_INITIAL_CAPITAL=1000000
BACKTEST_COMMISSION=0.0003
BACKTEST_SLIPPAGE=0.0001

# ------------------------------------------------------------
# 数据源配置
# ------------------------------------------------------------
DEFAULT_DATA_SOURCE=efinance
DATA_SOURCE_PRIORITY=["efinance","akshare","baostock","tickflow"]

# ------------------------------------------------------------
# TickFlow 配置（可选）
# ------------------------------------------------------------
# TickFlow 是一个金融数据服务，提供实时行情和历史数据
# 官网：https://tickflow.tech

# ------------------------------------------------------------
# 缓存配置
# ------------------------------------------------------------
CACHE_TTL=300
MAX_CACHE_SIZE=1000
REDIS_URL=redis://localhost:6379/0

# ------------------------------------------------------------
# 默认用户密码（仅开发环境，生产环境必须修改！）
# ------------------------------------------------------------
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_USER_PASSWORD=user123

# ------------------------------------------------------------
# API 配置
# ------------------------------------------------------------
API_PREFIX=/api/v1
