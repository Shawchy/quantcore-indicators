APP_NAME=Quant Analysis System
APP_VERSION=1.0.0
DEBUG=True

DATABASE_URL=sqlite+aiosqlite:///./data/sqlite/quant.db
DATA_DIR=./data
SQLITE_DIR=./data/sqlite
PARQUET_DIR=./data/parquet

CACHE_TTL=300
MAX_CACHE_SIZE=1000

DEFAULT_DATA_SOURCE=akshare

BACKTEST_INITIAL_CAPITAL=1000000
BACKTEST_COMMISSION=0.0003
BACKTEST_SLIPPAGE=0.0001

LOG_LEVEL=INFO
LOG_FILE=./logs/quant.log

CORS_ORIGINS=["http://localhost:5173", "http://127.0.0.1:5173"]

TUSHARE_TOKEN=
